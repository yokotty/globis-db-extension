{
  "manifest_version": 3,
  "name": "GLOBIS マイページ投稿拡張",
  "version": "0.1.2",
  "description": "Expands discussion posts that you have not liked yet.",
  "content_scripts": [
    {
      "matches": [
        "https://vc.globis.ac.jp/my/*"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
